local function makeEventCollector(folderName, cachedParts, lastScanRef, connRef)
    if connRef.main then pcall(function() connRef.main:Disconnect() end) connRef.main=nil end
    if connRef.desc then pcall(function() connRef.desc:Disconnect() end) connRef.desc=nil end
    while #cachedParts>0 do table.remove(cachedParts) end
    lastScanRef.t=tick()

    local function cacheParts()
        local folder=workspace:FindFirstChild(folderName) if not folder then return end
        local fresh={}
        for _, p in pairs(folder:GetDescendants()) do if p:IsA("BasePart") then table.insert(fresh,p) end end
        for _, p in pairs(folder:GetChildren()) do
            if p:IsA("BasePart") then
                local al=false for _, f in pairs(fresh) do if f==p then al=true break end end
                if not al then table.insert(fresh,p) end
            end
        end
        for i=1,#fresh do cachedParts[i]=fresh[i] end
        lastScanRef.t=tick()
    end

    cacheParts()

    local function onNewDesc(d)
        if not M.S.ValentineEnabled then return end
        if d:IsA("BasePart") then
            table.insert(cachedParts,d)
            local hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            safeTouchInterest(hrp,d,0) safeTouchInterest(hrp,d,1)
        end
    end

    local folder=workspace:FindFirstChild(folderName)
    if folder then
        connRef.desc=folder.DescendantAdded:Connect(onNewDesc)
    else
        task.spawn(function()
            local f2=workspace:WaitForChild(folderName,60)
            if f2 and M.S.ValentineEnabled then
                cacheParts()
                connRef.desc=f2.DescendantAdded:Connect(onNewDesc)
            end
        end)
    end

    connRef.main=RunService.Heartbeat:Connect(function()
        if not M.S.ValentineEnabled then return end
        pcall(function()
            local hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            if tick()-lastScanRef.t>5 then
                local alive={}
                for _, p in pairs(cachedParts) do if p and p.Parent then table.insert(alive,p) end end
                local folder2=workspace:FindFirstChild(folderName)
                if folder2 then
                    for _, p in pairs(folder2:GetDescendants()) do
                        if p:IsA("BasePart") then
                            local found=false for _, a in pairs(alive) do if a==p then found=true break end end
                            if not found then table.insert(alive,p) end
                        end
                    end
                end
                for i=1,#alive do cachedParts[i]=alive[i] end
                for i=#alive+1,#cachedParts do cachedParts[i]=nil end
                lastScanRef.t=tick()
            end
            for _, p in pairs(cachedParts) do
                if p and p.Parent then safeTouchInterest(hrp,p,0) safeTouchInterest(hrp,p,1) end
            end
        end)
    end)
end

local function stopEventCollector(cachedParts,connRef)
    if connRef.main then pcall(function() connRef.main:Disconnect() end) connRef.main=nil end
    if connRef.desc then pcall(function() connRef.desc:Disconnect() end) connRef.desc=nil end
    while #cachedParts>0 do table.remove(cachedParts) end
end

