-- [TOWER FINDING]
local function findTower() 
    local ok, t = pcall(function() return workspace.GameObjects.PlaceSpecific.root.Tower end) 
    if ok and t then return t end 
    for _, c in pairs(workspace:GetDescendants()) do 
        if c.Name=="Tower" and c:IsA("Model") then 
            local cnt=0 
            for _, d in pairs(c:GetDescendants()) do 
                if d:IsA("BasePart") then cnt+=1 end 
            end
            if cnt>5 then return c end 
        end 
    end 
    return nil 
end

local function getTowerBottomY() 
    local tower = findTower() 
    if not tower then return nil end 
    local minY = math.huge 
    for _, p in pairs(tower:GetDescendants()) do 
        if p:IsA("BasePart") then 
            local b=p.Position.Y-p.Size.Y/2 
            if b<minY then minY=b end 
        end 
    end 
    return minY==math.huge and nil or minY 
end

local function getTowerY() 
    local tower = findTower() 
    if not tower then return nil end 
    local ok,piv = pcall(function() return tower:GetPivot() end) 
    if ok and piv then return piv.Position.Y end 
    return nil 
end

