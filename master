function M.setHomePosition() 
    local ch=Player.Character 
    if not ch then return end 
    local hrp=ch:FindFirstChild("HumanoidRootPart") 
    if not hrp then return end 
    M.homePosition=hrp.CFrame 
end

function M.findBase() 
    local bases=workspace:FindFirstChild("Bases") 
    if not bases then return end 
    for _, base in pairs(bases:GetChildren()) do 
        pcall(function() 
            local pn=base.Title.TitleGui.Frame.PlayerName 
            if pn.Text==Player.Name or pn.Text==Player.DisplayName then 
                M.baseGUID=base.Name 
                local s1=base:FindFirstChild("slot 1 brainrot") 
                if s1 and s1:FindFirstChild("Root") then 
                    M.baseCFrame=s1.Root.CFrame 
                end 
            end 
        end) 
    end 
    if not M.homePosition then M.setHomePosition() end 
end

function M.getHomePosition() 
    if M.homePosition then return M.homePosition end 
    if M.baseCFrame   then return M.baseCFrame end 
    return CFrame.new(124,3.8,22) 
end

function M.mapFindCurrentMap() 
    local best,bc=nil,0 
    for _, c in pairs(workspace:GetChildren()) do 
        if c:IsA("Model") and c.Name:find("Map") and not c.Name:find("SharedInstances") then 
            if c:FindFirstChild("Spawners") or c:FindFirstChild("Gaps") or c:FindFirstChild("FirstFloor") or c:FindFirstChild("Ground") then return c end 
            local cnt=0 
            for _, d in pairs(c:GetDescendants()) do 
                if d:IsA("BasePart") then cnt+=1 end 
            end
            if cnt>10 then return c end 
        end
        if cnt and cnt>bc then bc=cnt best=c end 
    end 
    return best 
end

function M.detectWallZ() 
    local map=M.mapFindCurrentMap() 
    if not map then return end 
    local mzwalls=map:FindFirstChild("MzDHubWalls") 
    if not mzwalls then return end 
    local fw=mzwalls:FindFirstChild("FrontWall_1") 
    local bw=mzwalls:FindFirstChild("BackWall_1") 
    if fw then M._wallZ_front=fw.Position.Z-fw.Size.Z/2-3 end 
    if bw then M._wallZ_back=bw.Position.Z+bw.Size.Z/2+3 end 
end

function M.getCorridorZ() 
    M.detectWallZ() 
    return M.getHomePosition().Position.Z>=0 and M._wallZ_front or M._wallZ_back 
end

function M.tweenTo(cf) 
    local ch=Player.Character 
    if not ch then return false end 
    local hrp=ch:FindFirstChild("HumanoidRootPart") 
    if not hrp then return false end 
    local targetCF=M._isGod and CFrame.new(cf.Position.X,M.S.GodWalkY,cf.Position.Z) or cf 
    local d=(hrp.Position-targetCF.Position).Magnitude 
    local tw=TweenService:Create(hrp,TweenInfo.new(math.max(d/M.S.TweenSpeed,0.01),Enum.EasingStyle.Linear),{CFrame=targetCF}) 
    tw:Play() 
    tw.Completed:Wait() 
    return true 
end

function M.fastTween(cf) 
    local ch=Player.Character 
    if not ch then return false end 
    local hrp=ch:FindFirstChild("HumanoidRootPart") 
    if not hrp then return false end 
    local targetCF=M._isGod and CFrame.new(cf.Position.X,M.S.GodWalkY,cf.Position.Z) or cf 
    local d=(hrp.Position-targetCF.Position).Magnitude 
    local tw=TweenService:Create(hrp,TweenInfo.new(math.max(d/99999,0.005),Enum.EasingStyle.Linear),{CFrame=targetCF}) 
    tw:Play() 
    tw.Completed:Wait() 
    return true 
end

function M.corridorTween(cf) 
    local ch=Player.Character 
    if not ch then return false end 
    local hrp=ch:FindFirstChild("HumanoidRootPart") 
    if not hrp then return false end 
    local targetCF=M._isGod and CFrame.new(cf.Position.X,M.S.GodWalkY,cf.Position.Z) or cf 
    local d=(hrp.Position-targetCF.Position).Magnitude 
    local tw=TweenService:Create(hrp,TweenInfo.new(math.max(d/math.max(M.S.CorridorSpeed or 1500,50),0.01),Enum.EasingStyle.Linear),{CFrame=targetCF}) 
    tw:Play() 
    tw.Completed:Wait() 
    return true 
end

function M.safePathTo(targetCFrame) 
    local ch=Player.Character 
    if not ch then return false end 
    local hrp=ch:FindFirstChild("HumanoidRootPart") 
    if not hrp then return false end 
    local sp=hrp.Position 
    local ep=targetCFrame.Position 
    local SAFE_Z=M.getCorridorZ() 
    local SAFE_Y=M._isGod and M.S.GodWalkY or (M.getHomePosition().Position.Y+8) 
    M.fastTween(CFrame.new(sp.X,SAFE_Y,sp.Z))      
    task.wait(0.05) 
    M.corridorTween(CFrame.new(sp.X,SAFE_Y,SAFE_Z)) 
    task.wait(0.05) 
    M.corridorTween(CFrame.new(ep.X,SAFE_Y,SAFE_Z)) 
    task.wait(0.05) 
    M.corridorTween(CFrame.new(ep.X,SAFE_Y,ep.Z))   
    task.wait(0.05) 
    M.tweenTo(M._isGod and CFrame.new(ep.X,M.S.GodWalkY,ep.Z) or targetCFrame) 
    task.wait(0.05) 
    return true 
end

function M.safeReturnToBase() 
    local ch=Player.Character 
    if not ch then return end 
    local hrp=ch:FindFirstChild("HumanoidRootPart") 
    if not hrp then return end 
    local cp=hrp.Position 
    local hp=M.getHomePosition().Position 
    M.detectWallZ() 
    local SAFE_Z=M.getCorridorZ() 
    local SAFE_Y=M._isGod and M.S.GodWalkY or (hp.Y+8) 
    M.fastTween(CFrame.new(cp.X,SAFE_Y,cp.Z))   
    task.wait(0.05) 
    M.corridorTween(CFrame.new(cp.X,SAFE_Y,SAFE_Z)) 
    task.wait(0.05) 
    M.corridorTween(CFrame.new(hp.X,SAFE_Y,SAFE_Z)) 
    task.wait(0.05) 
    M.corridorTween(CFrame.new(hp.X,SAFE_Y,hp.Z))   
    task.wait(0.05) 
    M.tweenTo(CFrame.new(hp.X,M._isGod and M.S.GodWalkY or hp.Y,hp.Z)) 
    task.wait(0.05) 
end

function M.returnToBase() 
    if M._isGod then 
        local hp=M.getHomePosition().Position 
        M.tweenTo(CFrame.new(hp.X,M.S.GodWalkY,hp.Z)) 
    else 
        M.tweenTo(M.getHomePosition()) 
    end 
    task.wait(0.1) 
end

