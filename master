local function makeSmallBtn(parent,txt,color,cb)
    local b=Instance.new("TextButton") b.Size=UDim2.new(0,s(110),0,s(30))
    b.BackgroundColor3=color b.Text=txt b.TextColor3=Color3.white b.TextSize=s(11) b.Font=Enum.Font.GothamBold b.Parent=parent
    Instance.new("UICorner",b).CornerRadius=UDim.new(0,s(6))
    b.MouseButton1Click:Connect(cb) return b
end

