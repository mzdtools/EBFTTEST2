function M.getTrialBar() 
    local hud = Player.PlayerGui:FindFirstChild("TowerTrialHUD") 
    return hud and hud:FindFirstChild("TrialBar") 
end

function M.getTrialTimerText() 
    local bar = M.getTrialBar() 
    if not bar then return "" end 
    local lbl = bar:FindFirstChild("Timer") 
    return lbl and lbl.Text or "" 
end

function M.getTrialDeposits() 
    local bar = M.getTrialBar() 
    if not bar then return 0, 10 end 
    local lbl = bar:FindFirstChild("Deposits") 
    if not lbl then return 0, 10 end 
    local cur, goal = lbl.Text:match("(%d+)%s*/%s*(%d+)") 
    return tonumber(cur) or 0, tonumber(goal) or 10 
end

function M.getTrialRequiredRarity() 
    local bar = M.getTrialBar() 
    if not bar then return "?" end 
    local lbl = bar:FindFirstChild("Requirement") 
    if lbl and lbl.Text ~= "" then 
        local txt = lbl.Text:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$") 
        if txt ~= "" then return txt:match("Tower Trial:%s*(.+)") or txt end 
    end 
    for _, child in pairs(bar:GetDescendants()) do 
        if child:IsA("TextLabel") and child.Text ~= "" then 
            local txt = child.Text:gsub("<[^>]+>", "") 
            local rarity = txt:match("Tower Trial:%s*(.+)") 
            if rarity then return rarity:match("^%s*(.-)%s*$") end 
        end 
    end 
    return "?" 
end

function M.isTrialActive() 
    local bar = M.getTrialBar() 
    if not bar or not bar.Visible then return false end 
    local t = M.getTrialTimerText() 
    return t ~= "" and t ~= "00:00" and t ~= "0:00" 
end

function M.killTrialPopups() 
    pcall(function() 
        for _, gui in pairs(Player.PlayerGui:GetDescendants()) do 
            if gui:IsA("TextLabel") or gui:IsA("TextButton") then 
                local txt = string.lower(gui.Text) 
                if txt:match("claim") or txt:match("reward") or txt:match("worthy") then 
                    local f = gui:FindFirstAncestorWhichIsA("Frame") 
                    if f and f.Visible and f.Name ~= "TrialBar" and f.Name ~= "TowerTrialHUD" then f.Visible = false end 
                end 
            end 
        end 
    end) 
end

function M.getToolCount() 
    local count = 0 
    local bp = Player:FindFirstChild("Backpack") 
    if bp then for _, t in pairs(bp:GetChildren()) do if t:IsA("Tool") then count += 1 end end end 
    if Player.Character then for _, t in pairs(Player.Character:GetChildren()) do if t:IsA("Tool") then count += 1 end end end 
    return count 
end

function M.getLiveTowerCooldown() 
    local tower = findTower() 
    if not tower then return nil end 
    for _, d in pairs(tower:GetDescendants()) do 
        if d:IsA("TextLabel") and d.Text ~= "" then 
            local m, s = d.Text:match("(%d%d?):(%d%d)") 
            if m and s then return (tonumber(m) * 60) + tonumber(s) end 
        end 
    end 
    return nil 
end

function M.activateTrial() 
    local tower = findTower() 
    if not tower then M.Status.towerTrial="⚠️ Tower niet gevonden!" return false end 
    M.Status.towerTrial="🏃 Naar tower..." 
    if M._isGod then M.safePathTo(tower:GetPivot()*CFrame.new(0,3,0)) else M.tweenTo(tower:GetPivot()*CFrame.new(0,3,0)) end 
    for i=1,15 do 
        if not M.S.TowerTrialEnabled then return false end 
        M.Status.towerTrial="🏁 Activeer... ("..i..")" 
        fireAllPrompts(tower) 
        task.wait(0.6) 
        if M.isTrialActive() then 
            M.Status.towerTrial="✅ Actief: "..M.getTrialRequiredRarity() 
            return true 
        end 
    end 
    M.Status.towerTrial="⚠️ Mislukt" 
    return false 
end

function M.pickupTrialBrainrot() 
    local ab = workspace:FindFirstChild("ActiveBrainrots") 
    if not ab then M.Status.towerTrial="⚠️ Geen ActiveBrainrots" return false end 
    local req = M.getTrialRequiredRarity() 
    if req == "?" then M.Status.towerTrial="⚠️ Rarity onbekend" return false end 
    
    local list = {} 
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") 
    for _, folder in pairs(ab:GetChildren()) do 
        if folder.Name == req then 
            for _, b in pairs(folder:GetChildren()) do 
                local root = M.findBrainrotRoot(b) 
                if root then 
                    local dist = hrp and (hrp.Position - root.Position).Magnitude or 0 
                    table.insert(list, {b = b, root = root, dist = dist}) 
                end 
            end 
        end 
    end 
    table.sort(list, function(a, b2) return a.dist < b2.dist end) 
    
    if #list == 0 then M.Status.towerTrial="⏳ Geen "..req.."..." return false end 
    
    local entry = list[1] 
    local startParent = entry.b.Parent 
    local startTools = M.getToolCount() 
    
    M.Status.towerTrial="🧠 Naar "..req 
    if M._isGod then M.safePathTo(entry.root.CFrame * CFrame.new(0, 3, 0)) else M.tweenTo(entry.root.CFrame * CFrame.new(0, 3, 0)) end 
    
    for attempt = 1, 6 do 
        if not M.S.TowerTrialEnabled then return false end 
        if not entry.b or entry.b.Parent ~= startParent then break end 
        if M.getToolCount() > startTools then break end 
        M.forceGrabPrompt(entry.root) 
        M.forceGrabPrompt(entry.b) 
        task.wait(0.3) 
    end 
    
    if M.getToolCount() > startTools or (entry.b.Parent ~= startParent) then 
        M.Status.towerTrial="✅ Opgepakt!" 
        return true 
    end 
    return false 
end

function M.submitTrialBrainrot(depBefore) 
    local tower = findTower() 
    if not tower then return false end 
    M.Status.towerTrial="📦 Submit..." 
    if M._isGod then M.safePathTo(tower:GetPivot()*CFrame.new(0,3,0)) else M.tweenTo(tower:GetPivot()*CFrame.new(0,3,0)) end 
    
    local t0 = tick() 
    local deposited = false 
    while tick() - t0 < 8 do 
        if not M.S.TowerTrialEnabled then return false end 
        fireAllPrompts(tower) 
        task.wait(0.4) 
        local c,g = M.getTrialDeposits() 
        if c > depBefore then deposited = true break end 
    end 
    
    if deposited then 
        local ws = tick() 
        while true do 
            local c,g=M.getTrialDeposits() 
            if c > depBefore or (tick()-ws)>6 then break end 
            task.wait(0.2) 
        end 
        task.wait(3) 
        M.safeUnequip() 
        return true 
    end 
    M.safeUnequip() 
    return false 
end

function M.waitTrialCooldown() 
    local internalTimer = M.S.TTFallbackCooldown 
    while M.S.TowerTrialEnabled do 
        M.killTrialPopups() 
        local live = M.getLiveTowerCooldown() 
        if live ~= nil then 
            internalTimer = live==0 and 0 or live 
        else 
            internalTimer = internalTimer - 1 
        end 
        
        if internalTimer <= 0 then 
            M.Status.towerTrial="✅ Cooldown klaar!" 
            task.wait(2) 
            return true 
        end 
        
        local m=math.floor(internalTimer/60) 
        local s=math.floor(internalTimer%60) 
        M.Status.towerTrial=string.format("⏳ Cooldown: %d:%02d", m, s) 
        task.wait(1) 
    end 
    return false 
end

function M.startTowerTrial() 
    if M.towerTrialThread then return end 
    M.S.TowerTrialEnabled = true 
    M.Status.towerTrialCount = 0 
    M.towerTrialThread = task.spawn(function() 
        local state = "ACTIVATE" 
        local depBefore = 0 
        M.safeUnequip() 
        task.wait(0.3) 
        while M.S.TowerTrialEnabled do 
            local ok, err = pcall(function() 
                M.killTrialPopups() 
                if state == "ACTIVATE" then 
                    if M.isTrialActive() then state = "COLLECT" return end 
                    local lcd = M.getLiveTowerCooldown() 
                    if lcd and lcd > 0 then 
                        M.Status.towerTrial="⚠️ Cooldown..." 
                        state = "COOLDOWN" 
                        return 
                    end 
                    if M.activateTrial() then 
                        state = "COLLECT" 
                    else 
                        local cd = M.getLiveTowerCooldown() 
                        if cd and cd > 0 then state = "COOLDOWN" else task.wait(5) end 
                    end 
                    return 
                end 
                
                if state == "COLLECT" then 
                    if M.isDead() then M.waitForRespawn() task.wait(2) return end 
                    local cur, goal = M.getTrialDeposits() 
                    if cur >= goal then 
                        pcall(function() 
                            local rs=game:GetService("ReplicatedStorage") 
                            local r=rs:WaitForChild("Shared",3) and rs.Shared:WaitForChild("Remotes",3) and rs.Shared.Remotes:WaitForChild("Networking",3) and rs.Shared.Remotes.Networking:FindFirstChild("RE/Tower/TowerClaimConfirmed") 
                            if r then r:FireServer() end 
                        end) 
                        task.wait(1.5) 
                        M.Status.towerTrialCount += 1 
                        M.Status.towerTrial="🎉 KLAAR!" 
                        M.safeUnequip() 
                        state = "COOLDOWN" 
                        return 
                    end 
                    if M.pickupTrialBrainrot() then 
                        depBefore = cur 
                        state = "SUBMIT" 
                    else 
                        task.wait(1.5) 
                    end 
                    return 
                end 
                
                if state == "SUBMIT" then 
                    local cur,goal = M.getTrialDeposits() 
                    M.Status.towerTrial="📦 Submit ("..cur.."/"..goal..")" 
                    if not M.submitTrialBrainrot(depBefore) then M.safeUnequip() end 
                    state = "COLLECT" 
                    return 
                end 
                
                if state == "COOLDOWN" then 
                    if M.waitTrialCooldown() then state = "ACTIVATE" end 
                    return 
                end 
            end) 
            
            if not ok then M.Status.towerTrial="❌ Error" task.wait(3) end 
            task.wait(0.05) 
        end 
        M.Status.towerTrial="Idle" 
        M.towerTrialThread = nil 
    end) 
end

function M.stopTowerTrial() 
    M.S.TowerTrialEnabled = false 
    if M.towerTrialThread then pcall(task.cancel, M.towerTrialThread) M.towerTrialThread = nil end 
    M.Status.towerTrial="Idle" 
end

