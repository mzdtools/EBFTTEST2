    local SAFE_Z=M.getCorridorZ()
    local SAFE_Y=M._isGod and M.S.GodWalkY or (M.getHomePosition().Position.Y+8)
    M.fastTween(CFrame.new(sp.X,SAFE_Y,sp.Z))     task.wait(0.05)
    M.corridorTween(CFrame.new(sp.X,SAFE_Y,SAFE_Z)) task.wait(0.05)
    M.corridorTween(CFrame.new(ep.X,SAFE_Y,SAFE_Z)) task.wait(0.05)
    M.corridorTween(CFrame.new(ep.X,SAFE_Y,ep.Z))   task.wait(0.05)
    M.tweenTo(M._isGod and CFrame.new(ep.X,M.S.GodWalkY,ep.Z) or targetCFrame)
    task.wait(0.05) return true
end

function M.safeReturnToBase()
