-- ============================================
-- EXECUTOR SAFE WRAPPERS
-- ============================================
local _fti = firetouchinterest   or nil
local _fpp = fireproximityprompt or nil

local function safeTouchInterest(hrp, part, state)
    if _fti and hrp and part and part.Parent then
        pcall(_fti, hrp, part, state)
    end
end

local function safeFirePrompt(prompt)
    if not prompt then return end
    pcall(function()
        prompt.HoldDuration          = 0
        prompt.MaxActivationDistance = 99999
        prompt.RequiresLineOfSight   = false
        prompt.Enabled               = true
    end)
    if _fpp then 
        pcall(_fpp, prompt) 
    else
        -- Fallback voor executors zonder fireproximityprompt
        pcall(function()
            local old = prompt.HoldDuration
            prompt.HoldDuration = 0
            prompt:InputHoldBegin()
            task.wait()
            prompt:InputHoldEnd()
            prompt.HoldDuration = old
        end)
    end
end

local function fireAllPrompts(parent)
    if not parent then return end
    for _, d in pairs(parent:GetDescendants()) do
        if d:IsA("ProximityPrompt") then safeFirePrompt(d) end
    end
end

local function touchAllParts(hrp, parent)
    if not hrp or not parent then return end
    for _, d in pairs(parent:GetDescendants()) do
        if d:IsA("BasePart") then
            safeTouchInterest(hrp, d, 0)
            safeTouchInterest(hrp, d, 1)
        end
    end
end

