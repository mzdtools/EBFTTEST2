-- 2. LOGICA
local Farming = false

local function setStatus(txt)
    StatusLabel.Text = txt
end

local function safePrompt(prompt)
    if not prompt then return end
    pcall(function()
        prompt.HoldDuration = 0
        prompt.MaxActivationDistance = 999
        prompt.RequiresLineOfSight = false
        prompt.Enabled = true
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegin()
            task.wait()
            prompt:InputHoldEnd()
        end
    end)
end

local function tp(cf)
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = cf
    end
end

local function getTower()
    return workspace:FindFirstChild("GameObjects") and workspace.GameObjects:FindFirstChild("PlaceSpecific") and workspace.GameObjects.PlaceSpecific:FindFirstChild("root") and workspace.GameObjects.PlaceSpecific.root:FindFirstChild("Tower")
end

local function getHUD()
    return Player.PlayerGui:FindFirstChild("TowerTrialHUD") and Player.PlayerGui.TowerTrialHUD:FindFirstChild("TrialBar")
end

-- 3. DE FARM LOOP
ToggleBtn.MouseButton1Click:Connect(function()
    Farming = not Farming
    if Farming then
        ToggleBtn.Text = "STOP FARM"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        
        task.spawn(function()
            while Farming do
                local tower = getTower()
                if not tower then
                    setStatus("Tower niet gevonden!")
                    task.wait(1)
                else
                    local hud = getHUD()
                    -- Check of trial actief is (Timer text)
                    local timer = hud and hud:FindFirstChild("Timer") and hud.Timer.Text
                    local active = (timer and timer ~= "" and timer ~= "00:00")
                    
                    if not active then
                        setStatus("Activeren...")
                        tp(tower:GetPivot() * CFrame.new(0, 5, 0))
                        task.wait(0.2)
                        for _, d in pairs(tower:GetDescendants()) do
                            if d:IsA("ProximityPrompt") then safePrompt(d) end
                        end
                        task.wait(1)
                    else
                        -- Trial is actief, zoek brainrot
                        local req = hud:FindFirstChild("Requirement")
                        local reqTxt = req and req.Text or ""
                        local rarity = reqTxt:match("Tower Trial:%s*(.+)") or "Common"
                        
                        -- Check deposits
                        local dep = hud:FindFirstChild("Deposits")
                        local curStr = dep and dep.Text or "0/10"
                        local cur = tonumber(curStr:match("(%d+)/")) or 0
                        
                        if cur >= 10 then
                            setStatus("Klaar! Wachten...")
                            -- Probeer claim
                            pcall(function()
                                local r = game:GetService("ReplicatedStorage").Shared.Remotes.Networking["RE/Tower/TowerClaimConfirmed"]
                                r:FireServer()
                            end)
                            task.wait(2)
                        else
                            setStatus("Zoek: " .. rarity)
                            local found = false
                            local ab = workspace:FindFirstChild("ActiveBrainrots")
                            if ab then
                                for _, f in pairs(ab:GetChildren()) do
                                    if f.Name == rarity then
                                        for _, b in pairs(f:GetChildren()) do
                                            local root = b:FindFirstChild("Root") or b:FindFirstChild("RenderedBrainrot")
                                            if root then
                                                if root:IsA("Model") then root = root:FindFirstChild("Root") end
                                                if root then
                                                    found = true
                                                    -- Pakken
                                                    tp(root.CFrame * CFrame.new(0,3,0))
                                                    task.wait(0.3)
                                                    for _, p in pairs(b:GetDescendants()) do
                                                        if p:IsA("ProximityPrompt") then safePrompt(p) end
                                                    end
                                                    task.wait(0.5)
                                                    -- Inleveren
                                                    tp(tower:GetPivot() * CFrame.new(0, 5, 0))
                                                    task.wait(0.5)
                                                    for _, p in pairs(tower:GetDescendants()) do
                                                        if p:IsA("ProximityPrompt") then safePrompt(p) end
                                                    end
                                                    task.wait(1)
                                                    break
                                                end
                                            end
                                        end
                                    end
                                    if found then break end
                                end
                            end
                            if not found then
                                setStatus("Geen " .. rarity .. " gevonden")
                                task.wait(1)
                            end
                        end
                    end
                end
                task.wait(0.2)
            end
        end)
    else
        ToggleBtn.Text = "START FARM"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        setStatus("Gestopt")
    end
end)

