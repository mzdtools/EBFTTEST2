        if spaceBelow>=dh or spaceBelow>=spaceAbove then dropFrame.Position=UDim2.new(0,absPos.X,0,absPos.Y+btn.AbsoluteSize.Y)
        else dropFrame.Position=UDim2.new(0,absPos.X,0,absPos.Y-dh) end
