end

-- === TOWER TRIAL LOGICA ===
local function runTowerTrial()
    setStatus("Tower Trial Start...")
    while S.TowerTrial do
        pcall(function()
            local tower = workspace:FindFirstChild("GameObjects") and workspace.GameObjects:FindFirstChild("PlaceSpecific") and workspace.GameObjects.PlaceSpecific:FindFirstChild("root") and workspace.GameObjects.PlaceSpecific.root:FindFirstChild("Tower")
            
            if not tower then
                -- Fallback zoekfunctie
                for _, o in pairs(workspace:GetDescendants()) do if o.Name == "Tower" and o:IsA("Model") then tower = o break end end
            end

            if not tower then
                setStatus("⚠️ Geen Tower!")
                task.wait(2)
                return
            end

            local hud = Player.PlayerGui:FindFirstChild("TowerTrialHUD") and Player.PlayerGui.TowerTrialHUD:FindFirstChild("TrialBar")
            local timer = hud and hud:FindFirstChild("Timer") and hud.Timer.Text
            local active = (timer and timer ~= "" and timer ~= "00:00")

            if not active then
                setStatus("🏁 Activeren...")
                tp(tower:GetPivot() * CFrame.new(0, 5, 0))
                task.wait(0.3)
                for _, d in pairs(tower:GetDescendants()) do if d:IsA("ProximityPrompt") then safePrompt(d) end end
                task.wait(1.5)
            else
                local reqLabel = hud:FindFirstChild("Requirement")
                local reqTxt = reqLabel and reqLabel.Text or ""
                local rarity = reqTxt:match("Tower Trial:%s*(.+)") or "Common"
                
                local depLabel = hud:FindFirstChild("Deposits")
                local curStr = depLabel and depLabel.Text or "0/10"
                local cur = tonumber(curStr:match("(%d+)/")) or 0

                if cur >= 10 then
                    setStatus("🎉 KLAAR! Claimen...")
                    pcall(function()
                        game:GetService("ReplicatedStorage").Shared.Remotes.Networking["RE/Tower/TowerClaimConfirmed"]:FireServer()
                    end)
                    task.wait(2)
                else
                    setStatus("🧠 Zoek: " .. rarity .. " ("..cur.."/10)")
                    local found = false
                    local ab = workspace:FindFirstChild("ActiveBrainrots")
                    if ab then
                        for _, f in pairs(ab:GetChildren()) do
                            if f.Name == rarity then
                                for _, b in pairs(f:GetChildren()) do
                                    local root = b:FindFirstChild("Root") or b:FindFirstChild("RenderedBrainrot")
                                    if root then
                                        if root:IsA("Model") then root = root:FindFirstChild("Root") end
                                        if root then
                                            found = true
                                            tp(root.CFrame * CFrame.new(0,3,0))
                                            task.wait(0.3)
                                            for _, p in pairs(b:GetDescendants()) do if p:IsA("ProximityPrompt") then safePrompt(p) end end
                                            task.wait(0.5)
                                            tp(tower:GetPivot() * CFrame.new(0, 5, 0))
                                            task.wait(0.5)
                                            for _, p in pairs(tower:GetDescendants()) do if p:IsA("ProximityPrompt") then safePrompt(p) end end
                                            task.wait(1)
                                            break
                                        end
                                    end
                                end
                            end
                            if found then break end
                        end
                    end
                    if not found then
                        setStatus("⏳ Geen " .. rarity .. "...")
                        task.wait(1.5)
                    end
                end
            end
        end)
        task.wait(0.1)
    end
end

-- === GOD MODE LOGICA ===
local function runGodMode()
    -- Verstop kill parts
    task.spawn(function()
        while S.GodMode do
            pcall(function()
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("BasePart") and (v.Name:lower():find("kill") or v.Name:lower():find("damage")) then
                        v.CanTouch = false
                        v.CanCollide = false
                        v.Transparency = 0.8
                    end
                end
                -- Verstop vloeren voor visual
                local map = nil
                for _, c in pairs(workspace:GetChildren()) do if c.Name:find("Map") and not c.Name:find("Shared") then map = c break end end
                if map then
                    for _, d in pairs(map:GetDescendants()) do
                        if d:IsA("BasePart") and (d.Name == "BridgeFloor" or d.Name == "FirstFloor" or d.Name == "Ground") then
                            d.CanCollide = false
                            d.Transparency = 0.9
                        end
                    end
                end
            end)
            task.wait(1)
        end
    end)
    
    -- Loop handler
    while S.GodMode do
        pcall(function()
            local hrp = Player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Forceer hoogte als we vallen
                if hrp.Position.Y < S.WalkY - 5 then
                    hrp.CFrame = CFrame.new(hrp.Position.X, S.WalkY, hrp.Position.Z)
                    hrp.Velocity = Vector3.zero
                end
                -- Forceer state
                local hum = Player.Character:FindFirstChild("Humanoid")
                if hum then
                    hum:ChangeState(Enum.HumanoidStateType.Running)
                    hum.Health = hum.MaxHealth
                end
            end
        end)
        task.wait()
    end
end

-- === FARM LOGICA (Brainrots) ===
local function runFarm()
    setStatus("Farm Start...")
    while S.Farming do
        pcall(function()
            local ab = workspace:FindFirstChild("ActiveBrainrots")
            local found = false
            if ab then
                for _, f in pairs(ab:GetChildren()) do
                    if S.TargetRarity == "Any" or f.Name == S.TargetRarity then
                        for _, b in pairs(f:GetChildren()) do
                            local root = b:FindFirstChild("Root") or b:FindFirstChild("RenderedBrainrot")
                            if root then
                                if root:IsA("Model") then root = root:FindFirstChild("Root") end
                                if root then
                                    found = true
                                    setStatus("Pakken: " .. f.Name)
                                    tp(root.CFrame * CFrame.new(0,3,0))
                                    task.wait(0.3)
                                    for _, p in pairs(b:GetDescendants()) do if p:IsA("ProximityPrompt") then safePrompt(p) end end
                                    task.wait(0.2)
                                    -- Base slot droppen (simpel: slot 5)
                                    -- Voor nu alleen collecten om errors te voorkomen in simple mode
                                    break
                                end
                            end
                        end
                    end
                    if found then break end
                end
            end
            if not found then
                setStatus("Zoeken naar " .. S.TargetRarity .. "...")
                task.wait(1)
            end
        end)
        task.wait(0.2)
    end
end


