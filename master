-- Controleert of een BasePart door MzD Hub zelf aangemaakt is
local function isMzDPart(obj)
    if not obj or not obj:IsA("BasePart") then return false end
    local n = obj.Name
    if n == "MzDGodFloor" or n == "MzDGodCatchFloor" or n == "MzDGodFloorStripe" then return true end
    local p = obj.Parent
    while p do
        if p.Name == "MzDHubWalls" or p == "MzDGodPreview" then return true end
        p = p.Parent
    end
    return false
end

-- Gecentraliseerde PlotAction invoker met throttle + pcall
-- KRITIEK: Elke remote-call kan falen na een game-update → altijd pcall
local _lastPlotCall = 0
local PLOT_COOLDOWN = 0.15

local function throttledPlotAction(action, guid, slot)
    local now = tick()
    local wait = PLOT_COOLDOWN - (now - _lastPlotCall)
    if wait > 0 then twait(wait) end
    _lastPlotCall = tick()
    if not M.PlotAction then return false end
    if slot then
        return pcall(function() M.PlotAction:InvokeServer(action, guid, slot) end)
    elseif guid then
        return pcall(function() M.PlotAction:InvokeServer(action, guid) end)
    else
        return pcall(function() M.PlotAction:InvokeServer(action) end)
    end
end

